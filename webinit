# ============================================================================
# Apply Options (--no-css, --no-js)
# ============================================================================

apply_no_css() {
    local base="$1"
    # Remove all css/ directories recursively (e.g. css/, public/css/)
    find "$base" -type d -name "css" | while read -r dir; do
        rm -rf "$dir"
        local rel="${dir#$base/}"
        print_info "Removed ${rel}/ directory (--no-css)"
    done
    # Remove any remaining .css files
    find "$base" -type f -name "*.css" -delete 2>/dev/null
    # Remove CSS link tags from HTML, EJS, and PHP files
    find "$base" \( -name "*.html" -o -name "*.ejs" -o -name "*.php" \) \
        -exec sed -i '/<link[^>]*stylesheet[^>]*\.css/d' {} \; 2>/dev/null
}

apply_no_js() {
    local base="$1"
    # Remove all js/ directories recursively (e.g. js/, public/js/)
    find "$base" -type d -name "js" | while read -r dir; do
        rm -rf "$dir"
        local rel="${dir#$base/}"
        print_info "Removed ${rel}/ directory (--no-js)"
    done
    # Remove src/ directory for SPA templates (but not if server.js exists — that's a backend)
    if [ -d "$base/src" ] && [ ! -f "$base/server.js" ]; then
        rm -rf "$base/src"
        print_info "Removed src/ directory (--no-js)"
    fi
    # Remove frontend .js files from public/ and root, but keep server-side files
    find "$base" -type f -name "*.js" \
        ! -path "$base/server.js" \
        ! -path "$base/routes/*" \
        ! -path "$base/controllers/*" \
        ! -path "$base/models/*" \
        ! -path "$base/middleware/*" \
        ! -path "$base/config/*" \
        -delete 2>/dev/null
    # Remove script tags from HTML, EJS, and PHP files
    find "$base" \( -name "*.html" -o -name "*.ejs" -o -name "*.php" \) \
        -exec sed -i '/<script[^>]*\.js/d' {} \; 2>/dev/null
}

