    create_file_with_content "$base/src/router.js" "// Simple SPA Router
export class Router {
    constructor(rootElement) {
        this.root = rootElement;
        this.routes = {};
    }

    addRoute(path, viewFn) {
        this.routes[path] = viewFn;
    }

    navigate(path) {
        window.history.pushState({}, '', path);
        this.render(path);
    }

    render(path) {
        const viewFn = this.routes[path] || this.routes['/'];
        if (viewFn) {
            this.root.innerHTML = '';
            this.root.appendChild(viewFn());
        }
    }

    init() {
        window.addEventListener('popstate', () => this.render(window.location.pathname));
        this.render(window.location.pathname);
    }
}"

