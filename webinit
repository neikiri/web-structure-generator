# ============================================================================
# Main Logic
# ============================================================================

# No arguments
if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

# Parse first argument
COMMAND="$1"
shift

case "$COMMAND" in
    help)
        show_help
        exit 0
        ;;
    version)
        show_version
        exit 0
        ;;
    templates)
        show_templates
        exit 0
        ;;
    -*)
        print_error "Invalid command: ${COMMAND}"
        echo -e "Run ${CYAN}webinit help${NC} for usage information."
        exit 1
        ;;
esac

# If we get here, COMMAND is the site name
SITE_NAME="$COMMAND"

# Validate site name
if [[ ! "$SITE_NAME" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    print_error "Invalid site name: '${SITE_NAME}'"
    echo "  Site name can only contain letters, numbers, dots, hyphens, and underscores."
    exit 1
fi

# Parse options
TEMPLATE=""
USE_GIT=false
USE_GITIGNORE=false
USE_SERVE=false
PORT=8000
USE_FORCE=false
USE_OPEN=false
NO_CSS=false
NO_JS=false

while [ $# -gt 0 ]; do
    case "$1" in
        --template)
            if [ -z "$2" ] || [[ "$2" == --* ]]; then
                print_error "Missing template name after --template"
                exit 1
            fi
            TEMPLATE="$2"
            shift 2
            ;;
        --git)
            USE_GIT=true
            shift
            ;;
        --gitignore)
            USE_GITIGNORE=true
            shift
            ;;
        --serve)
            USE_SERVE=true
            shift
            ;;
        --port)
            if [ -z "$2" ] || [[ "$2" == --* ]]; then
                print_error "Missing port number after --port"
                exit 1
            fi
            if ! [[ "$2" =~ ^[0-9]+$ ]] || [ "$2" -lt 1 ] || [ "$2" -gt 65535 ]; then
                print_error "Invalid port number: $2 (must be 1-65535)"
                exit 1
            fi
            PORT="$2"
            shift 2
            ;;
        --force)
            USE_FORCE=true
            shift
            ;;
        --open)
            USE_OPEN=true
            shift
            ;;
        --no-css)
            NO_CSS=true
            shift
            ;;
        --no-js)
            NO_JS=true
            shift
            ;;
        *)
            print_error "Unknown option: $1"
            echo -e "Run ${CYAN}webinit help${NC} for usage information."
            exit 1
            ;;
    esac
done

# Check if directory exists
if [ -d "$SITE_NAME" ]; then
    if [ "$USE_FORCE" = true ]; then
        print_warning "Overwriting existing directory: ${SITE_NAME}"
        rm -rf "$SITE_NAME"
    else
        print_error "Directory '${SITE_NAME}' already exists."
        echo "  Use --force to overwrite."
        exit 1
    fi
fi

# Validate template name
VALID_TEMPLATES=("landing-page" "blog" "portfolio" "webapp" "ecommerce" "fullstack-node" "php-classic" "dashboard" "api-rest" "docs")
if [ -n "$TEMPLATE" ]; then
    TEMPLATE_VALID=false
    for t in "${VALID_TEMPLATES[@]}"; do
        if [ "$t" = "$TEMPLATE" ]; then
            TEMPLATE_VALID=true
            break
        fi
    done
    if [ "$TEMPLATE_VALID" = false ]; then
        print_error "Unknown template: '${TEMPLATE}'"
        echo "  Available templates: ${VALID_TEMPLATES[*]}"
        echo -e "  Run ${CYAN}webinit templates${NC} to see all templates."
        exit 1
    fi
fi

# Create project
echo ""
print_info "Creating project: ${BOLD}${SITE_NAME}${NC}"

if [ -n "$TEMPLATE" ]; then
    print_info "Using template: ${BOLD}${TEMPLATE}${NC}"
    case "$TEMPLATE" in
        landing-page)   template_landing_page "$SITE_NAME" ;;
        blog)           template_blog "$SITE_NAME" ;;
        portfolio)      template_portfolio "$SITE_NAME" ;;
        webapp)         template_webapp "$SITE_NAME" ;;
        ecommerce)      template_ecommerce "$SITE_NAME" ;;
        fullstack-node) template_fullstack_node "$SITE_NAME" ;;
        php-classic)    template_php_classic "$SITE_NAME" ;;
        dashboard)      template_dashboard "$SITE_NAME" ;;
        api-rest)       template_api_rest "$SITE_NAME" ;;
        docs)           template_docs "$SITE_NAME" ;;
    esac
else
    template_default "$SITE_NAME"
fi

# Apply --no-css
if [ "$NO_CSS" = true ]; then
    apply_no_css "$SITE_NAME"
fi

# Apply --no-js
if [ "$NO_JS" = true ]; then
    apply_no_js "$SITE_NAME"
fi

# Apply --gitignore
if [ "$USE_GITIGNORE" = true ]; then
    create_gitignore "$SITE_NAME"
    print_success "Created .gitignore"
fi

# Apply --git
if [ "$USE_GIT" = true ]; then
    if command -v git &> /dev/null; then
        (cd "$SITE_NAME" && git init -q)
        print_success "Initialized Git repository"
    else
        print_error "Git is not installed. Install with: sudo apt install git"
    fi
fi

# Set proper permissions recursively
find "$SITE_NAME" -type d -exec chmod 755 {} \;
find "$SITE_NAME" -type f -exec chmod 644 {} \;

print_success "Project created successfully!"
echo ""
show_tree "$SITE_NAME"
echo ""

# Apply --open
if [ "$USE_OPEN" = true ]; then
    if command -v code &> /dev/null; then
        code "$SITE_NAME"
        print_success "Opened in VS Code"
    else
        print_warning "VS Code CLI (code) not found. Open the project manually."
    fi
fi

# Apply --serve
if [ "$USE_SERVE" = true ]; then
    # Determine serve directory
    SERVE_DIR="$SITE_NAME"
    if [ -d "$SITE_NAME/public" ]; then
        SERVE_DIR="$SITE_NAME/public"
    fi

    if command -v php &> /dev/null; then
        print_info "Starting PHP development server on port ${PORT}..."
        echo -e "  ${DIM}Serving from: ${SERVE_DIR}${NC}"
        echo -e "  ${DIM}URL: http://localhost:${PORT}${NC}"
        echo -e "  ${DIM}Press Ctrl+C to stop${NC}"
        echo ""
        php -S "localhost:${PORT}" -t "$SERVE_DIR"
    else
        print_warning "PHP is not installed."
        echo -n "  Would you like to install PHP? [y/N]: "
        read -r INSTALL_PHP
        if [[ "$INSTALL_PHP" =~ ^[Yy]$ ]]; then
            print_info "Installing PHP..."
            if sudo apt update -qq && sudo apt install -y -qq php; then
                print_success "PHP installed successfully!"
                print_info "Starting PHP development server on port ${PORT}..."
                echo -e "  ${DIM}Serving from: ${SERVE_DIR}${NC}"
                echo -e "  ${DIM}URL: http://localhost:${PORT}${NC}"
                echo -e "  ${DIM}Press Ctrl+C to stop${NC}"
                echo ""
                php -S "localhost:${PORT}" -t "$SERVE_DIR"
            else
                print_error "Failed to install PHP."
                exit 1
            fi
        else
            print_info "Skipping server. Install PHP manually: sudo apt install php"
        fi
    fi
fi

exit 0
