# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m' # No Color

# ============================================================================
# Helper Functions
# ============================================================================

print_success() {
    echo -e "${GREEN}✔${NC} $1"
}

print_error() {
    echo -e "${RED}✖${NC} $1"
}

print_info() {
    echo -e "${BLUE}ℹ${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

print_header() {
    echo -e "\n${BOLD}${CYAN}$1${NC}\n"
}

create_dir() {
    mkdir -p "$1"
    chmod 755 "$1"
}

create_file_with_content() {
    local filepath="$1"
    local content="$2"
    echo "$content" > "$filepath"
    chmod 644 "$filepath"
}

create_empty_file() {
    touch "$1"
    chmod 644 "$1"
}

